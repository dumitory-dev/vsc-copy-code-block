{
  "name": "vsc-code-block-copier",
  "displayName": "Code Block Copier",
  "description": "Copy code blocks with line numbers and file paths for documentation and sharing",
  "version": "0.0.5",
  "publisher": "dumitory-dev",
  "private": false,
  "license": "MIT",
  "author": {
    "name": "dumitory-dev"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "icon": "images/icon.png",
  "galleryBanner": {
    "color": "#1E1E1E",
    "theme": "dark"
  },
  "categories": [
    "Other",
    "Formatters",
    "Snippets"
  ],
  "keywords": [
    "code",
    "block",
    "copy",
    "line numbers",
    "formatting",
    "documentation",
    "sharing",
    "export"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/dumitory-dev/vsc-copy-code-block"
  },
  "bugs": {
    "url": "https://github.com/dumitory-dev/vsc-copy-code-block/issues"
  },
  "homepage": "https://github.com/yourusername/vsc-code-block-copier#readme",
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "configuration": {
      "title": "Code Block Copier",
      "properties": {
        "vsc-code-block-copier.screenshotOutputFolder": {
          "type": "string",
          "default": "",
          "markdownDescription": "Folder where generated screenshots are saved. If empty, screenshots are saved to `~/Pictures/vsc-code-block-copier`.\n\n**Tip:** run the command **Code Block Copier: Set Screenshot Output Folder** to pick a folder visually instead of typing the path."
        },
        "vsc-code-block-copier.screenshotTheme": {
          "type": "string",
          "default": "vscode-dark",
          "enum": [
            "vscode-dark",
            "vscode-light",
            "github-dark",
            "github-light",
            "monokai",
            "dracula",
            "nord",
            "solarized-dark",
            "solarized-light",
            "one-dark",
            "one-light"
          ],
          "enumDescriptions": [
            "VS Code Dark — default dark theme matching the VS Code editor",
            "VS Code Light — clean light theme, good for printed docs",
            "GitHub Dark — matches GitHub's dark mode",
            "GitHub Light — matches GitHub's light mode",
            "Monokai — classic warm dark theme",
            "Dracula — popular purple-tinted dark theme",
            "Nord — cool arctic dark theme",
            "Solarized Dark — Ethan Schoonover's low-contrast dark palette",
            "Solarized Light — Ethan Schoonover's low-contrast light palette",
            "Atom One Dark — Atom editor's dark theme",
            "Atom One Light — Atom editor's light theme"
          ],
          "markdownDescription": "Color palette used when rendering screenshots.\n\n[Open Visual Theme Picker](command:vsc-code-block-copier.openScreenshotThemePicker) to pick a theme with live previews and radio buttons."
        }
      }
    },
    "submenus": [
      {
        "id": "vsc-code-block-copier.contextSubmenu",
        "label": "Code Block Copier"
      }
    ],
    "commands": [
      {
        "command": "vsc-code-block-copier.copyCodeBlock",
        "title": "Code Block Copier: Copy Code Block"
      },
      {
        "command": "vsc-code-block-copier.copyCodeBlockAppend",
        "title": "Code Block Copier: Copy Code Block (Append)"
      },
      {
        "command": "vsc-code-block-copier.copyCodeBlockMarkdown",
        "title": "Code Block Copier: Copy Code Block (Markdown)"
      },
      {
        "command": "vsc-code-block-copier.copyCodeBlockMarkdownAppend",
        "title": "Code Block Copier: Copy Code Block (Markdown, Append)"
      },
      {
        "command": "copyCodeBlock.generateScreenshot",
        "title": "Code Block Copier: Generate Code Screenshot"
      },
      {
        "command": "vsc-code-block-copier.setScreenshotOutputFolder",
        "title": "Code Block Copier: Set Screenshot Output Folder"
      },
      {
        "command": "vsc-code-block-copier.openScreenshotThemePicker",
        "title": "Code Block Copier: Choose Screenshot Theme (Visual Picker)"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "vsc-code-block-copier.openScreenshotThemePicker",
          "when": "false"
        }
      ],
      "editor/context": [
        {
          "submenu": "vsc-code-block-copier.contextSubmenu",
          "group": "9_cutcopypaste",
          "when": "editorTextFocus"
        }
      ],
      "vsc-code-block-copier.contextSubmenu": [
        {
          "command": "vsc-code-block-copier.copyCodeBlock",
          "group": "1_main"
        },
        {
          "command": "vsc-code-block-copier.copyCodeBlockAppend",
          "group": "1_main"
        },
        {
          "command": "vsc-code-block-copier.copyCodeBlockMarkdown",
          "group": "2_markdown"
        },
        {
          "command": "vsc-code-block-copier.copyCodeBlockMarkdownAppend",
          "group": "2_markdown"
        },
        {
          "command": "copyCodeBlock.generateScreenshot",
          "group": "3_export"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "package": "npm run compile:types && node esbuild.js --production",
    "compile": "npm-run-all compile:*",
    "compile:types": "tsc --noEmit",
    "compile:lint": "eslint src --ext ts",
    "compile:build": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "test": "tsc && vscode-test",
    "test:unit": "tsc && mocha --ui tdd out/test/codeBlock.test.js out/test/clipboard.test.js"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.19.37",
    "@types/vscode": "^1.90.0",
    "@typescript-eslint/eslint-plugin": "^8.22.0",
    "@typescript-eslint/parser": "^8.22.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.4.1",
    "esbuild": "^0.25.0",
    "eslint": "^9.19.0",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.7.3"
  },
  "overrides": {
    "serialize-javascript": "^7.0.3"
  },
  "extensionDependencies": [],
  "capabilities": {
    "virtualWorkspaces": true,
    "untrustedWorkspaces": {
      "supported": true
    }
  },
  "dependencies": {
    "@resvg/resvg-wasm": "^2.6.2",
    "highlight.js": "^11.11.1"
  }
}
